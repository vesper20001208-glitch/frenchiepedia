---
// French Bulldog Mascot - playful companion for the site
---

<div class="mascot-wrapper" id="frenchie-mascot">
  <div class="mascot-body" id="mascot-body">
    <svg viewBox="0 0 240 280" xmlns="http://www.w3.org/2000/svg" class="frenchie-svg">
      <!-- Tail -->
      <g class="tail">
        <path d="M 192 164 Q 210 144 218 154 Q 226 164 214 176" fill="none" stroke="#8B6914" stroke-width="5" stroke-linecap="round">
          <animate attributeName="d" dur="1.5s" repeatCount="indefinite"
            values="M 192 164 Q 210 144 218 154 Q 226 164 214 176;
                    M 192 164 Q 210 148 222 156 Q 232 164 218 178;
                    M 192 164 Q 210 144 218 154 Q 226 164 214 176"/>
        </path>
      </g>

      <!-- Body -->
      <ellipse cx="120" cy="200" rx="78" ry="62" fill="#D4A843"/>
      <ellipse cx="120" cy="208" rx="50" ry="42" fill="#F0DCB8"/>

      <!-- Back legs -->
      <ellipse cx="168" cy="250" rx="18" ry="12" fill="#C49A3C"/>
      <ellipse cx="62" cy="250" rx="18" ry="12" fill="#C49A3C"/>

      <!-- Front paws -->
      <ellipse cx="168" cy="258" rx="16" ry="8" fill="#E8C88A"/>
      <ellipse cx="62" cy="258" rx="16" ry="8" fill="#E8C88A"/>

      <rect x="50" y="240" width="24" height="16" rx="8" fill="#D4A843"/>
      <rect x="156" y="240" width="24" height="16" rx="8" fill="#D4A843"/>

      <!-- Head -->
      <g class="head">
        <animateTransform attributeName="transform" type="translate" dur="3s" repeatCount="indefinite"
          values="0,0; 2,-3; 0,0" additive="sum"/>

        <ellipse cx="120" cy="118" rx="84" ry="74" fill="#D4A843"/>
        <ellipse cx="120" cy="132" rx="56" ry="46" fill="#F0DCB8"/>

        <!-- Left ear -->
        <g class="ear left-ear">
          <path d="M 54 76 Q 38 36 50 28 Q 62 20 78 52" fill="#8B6914"/>
          <path d="M 58 68 Q 48 40 56 34 Q 64 28 74 52" fill="#C49A3C"/>
          <animateTransform attributeName="transform" type="rotate" dur="4s" repeatCount="indefinite"
            values="0 60 60; 4 60 60; 0 60 60;-3 60 60; 0 60 60"/>
        </g>

        <!-- Right ear -->
        <g class="ear right-ear">
          <path d="M 186 76 Q 202 36 190 28 Q 178 20 162 52" fill="#8B6914"/>
          <path d="M 182 68 Q 192 40 184 34 Q 176 28 166 52" fill="#C49A3C"/>
          <animateTransform attributeName="transform" type="rotate" dur="4s" repeatCount="indefinite"
            values="0 180 60; -4 180 60; 0 180 60; 3 180 60; 0 180 60"/>
        </g>

        <!-- Eyes -->
        <g class="eyes">
          <ellipse cx="92" cy="112" rx="16" ry="17" fill="white"/>
          <ellipse cx="148" cy="112" rx="16" ry="17" fill="white"/>
          <ellipse cx="94" cy="114" rx="8" ry="9" fill="#2D1B00"/>
          <ellipse cx="150" cy="114" rx="8" ry="9" fill="#2D1B00"/>
          <ellipse cx="97" cy="109" rx="3.5" ry="3" fill="white"/>
          <ellipse cx="153" cy="109" rx="3.5" ry="3" fill="white"/>
        </g>

        <!-- Nose -->
        <ellipse cx="120" cy="138" rx="14" ry="10" fill="#2D1B00"/>
        <ellipse cx="116" cy="134" rx="5" ry="3" fill="#4A3520" opacity="0.6"/>

        <!-- Mouth -->
        <path d="M 112 146 Q 120 156 128 146" fill="none" stroke="#2D1B00" stroke-width="2" stroke-linecap="round"/>

        <!-- Tongue -->
        <g class="tongue">
          <path d="M 116 148 Q 120 162 124 148" fill="#FF7B89"/>
          <animate attributeName="opacity" dur="2s" repeatCount="indefinite"
            values="0;0;1;1;1;1;0;0" keyTimes="0;0.1;0.2;0.4;0.6;0.8;0.9;1"/>
        </g>

        <!-- Wrinkle lines -->
        <path d="M 100 94 Q 110 90 120 94 Q 130 90 140 94" fill="none" stroke="#C49A3C" stroke-width="1.5" opacity="0.6"/>
        <path d="M 104 98 Q 112 95 120 98 Q 128 95 136 98" fill="none" stroke="#C49A3C" stroke-width="1.5" opacity="0.4"/>
      </g>
    </svg>
  </div>
</div>

<style>
  .mascot-wrapper {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 120px;
    height: 140px;
    z-index: 9999;
    cursor: pointer;
    transition: transform 0.3s ease;
    user-select: none;
  }
  .mascot-wrapper:hover {
    transform: scale(1.1);
  }
  .mascot-body {
    width: 100%;
    height: 100%;
    animation: idleBreathe 3s ease-in-out infinite;
  }
  .frenchie-svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.15));
  }

  @keyframes idleBreathe {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .mascot-wrapper.entry {
    animation: bounceIn 1s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
  }

  @keyframes bounceIn {
    0% { transform: scale(0) rotate(-10deg); opacity: 0; }
    40% { transform: scale(1.15) rotate(3deg); opacity: 1; }
    60% { transform: scale(0.95) rotate(-2deg); }
    80% { transform: scale(1.05) rotate(1deg); }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }

  .mascot-wrapper.excited {
    animation: excitedJump 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  @keyframes excitedJump {
    0% { transform: scale(1) translateY(0); }
    30% { transform: scale(1.2) translateY(-30px) rotate(5deg); }
    50% { transform: scale(1.1) translateY(-10px) rotate(-3deg); }
    70% { transform: scale(1.15) translateY(-5px) rotate(2deg); }
    100% { transform: scale(1) translateY(0); }
  }

  .mascot-wrapper.wiggle {
    animation: wiggle 0.5s ease-in-out;
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(0); }
    20% { transform: rotate(-8deg); }
    40% { transform: rotate(8deg); }
    60% { transform: rotate(-5deg); }
    80% { transform: rotate(5deg); }
  }

  .speech-bubble {
    position: absolute;
    top: -30px;
    right: 10px;
    background: white;
    border-radius: 12px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 600;
    color: #1a1a2e;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    opacity: 0;
    transition: opacity 0.3s ease;
    white-space: nowrap;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .speech-bubble::after {
    content: '';
    position: absolute;
    bottom: -6px;
    right: 20px;
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 6px solid white;
  }

  .speech-bubble.show {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .mascot-wrapper { width: 80px; height: 94px; bottom: 10px; right: 10px; }
    .speech-bubble { font-size: 11px; padding: 4px 10px; right: 0; top: -25px; }
  }
</style>

<script>
  (function() {
    const wrapper = document.getElementById('frenchie-mascot');
    if (!wrapper) return;

    const phrases = [
      "🐾 Welcome!", "👋 Hey there!", "🦴 Wanna play?",
      "💛 Woof!", "🐶 Frenchie power!", "✨ Check the articles!"
    ];

    let bubbleTimer = null;
    let visitCount = 0;

    setTimeout(() => {
      wrapper.classList.add('entry');
      setTimeout(() => showBubble(), 1200);
    }, 500);

    let idleTimer = setInterval(() => {
      if (document.hidden) return;
      wrapper.classList.add('wiggle');
      setTimeout(() => wrapper.classList.remove('wiggle'), 500);
      showBubble();
    }, 30000);

    wrapper.addEventListener('click', function() {
      wrapper.classList.remove('excited');
      void wrapper.offsetWidth;
      wrapper.classList.add('excited');

      visitCount++;
      let msg;
      if (visitCount === 1) msg = "🎉 You clicked me!";
      else if (visitCount === 2) msg = "😆 Again! Again!";
      else if (visitCount >= 5) msg = "🥰 You're my best friend!";
      else msg = phrases[Math.floor(Math.random() * phrases.length)];

      showBubble(msg);
    });

    wrapper.addEventListener('mousemove', function(e) {
      const rect = wrapper.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
      const deltaX = (e.clientX - centerX) / 20;
      const deltaY = (e.clientY - centerY) / 20;
      const cx = Math.max(-4, Math.min(4, deltaX));
      const cy = Math.max(-3, Math.min(3, deltaY));

      const eyes = wrapper.querySelector('.eyes');
      if (eyes) {
        eyes.style.transform = `translate(${cx}px, ${cy}px)`;
        eyes.style.transition = 'transform 0.1s ease';
      }
    });

    wrapper.addEventListener('mouseleave', function() {
      const eyes = wrapper.querySelector('.eyes');
      if (eyes) {
        eyes.style.transform = 'translate(0, 0)';
        eyes.style.transition = 'transform 0.3s ease';
      }
    });

    function showBubble(text) {
      if (bubbleTimer) clearTimeout(bubbleTimer);
      let bubble = wrapper.querySelector('.speech-bubble');
      if (!bubble) {
        bubble = document.createElement('div');
        bubble.className = 'speech-bubble';
        wrapper.appendChild(bubble);
      }
      bubble.textContent = text || phrases[Math.floor(Math.random() * phrases.length)];
      bubble.classList.add('show');
      bubbleTimer = setTimeout(() => bubble.classList.remove('show'), 3000);
    }

    window.addEventListener('beforeunload', function() {
      if (idleTimer) clearInterval(idleTimer);
      if (bubbleTimer) clearTimeout(bubbleTimer);
    });
  })();
</script>
